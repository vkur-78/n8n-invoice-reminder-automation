    {
      "parameters": {
        "jsCode": "// Group invoices customer-wise\nconst customers = {};\n\nfor (const item of $input.all()) {\n\n  const r = item.json;\n\n  const customer = r[\"Client Name\"];\n\n  if (!customers[customer]) {\n    customers[customer] = {\n      customerName: customer,\n      salesPerson: r[\"Sales Person Name\"],\n      salesPhone: r[\"Sales Person Contact Number\"],\n      creditLimit: Number(r[\"Credit Limit (₹)\"] || 0),\n      totalOutstanding: 0,\n      invoices: []\n    };\n  }\n\n  customers[customer].totalOutstanding += Number(r[\"Balance Outstanding (₹)\"] || 0);\n\n  customers[customer].invoices.push({\n    invoiceNumber: r[\"Invoice Number\"],\n    invoiceDate: r[\"Invoice Date\"],\n    amount: Number(r[\"Balance Outstanding (₹)\"] || 0)\n  });\n\n}\n\nconst output = [];\n\nfor (const customer of Object.values(customers)) {\n\n  if (customer.totalOutstanding > customer.creditLimit) {\n\n    output.push({\n      json: {\n\n        customerName: customer.customerName,\n\n        salesPerson: customer.salesPerson,\n\n        salesPhone: customer.salesPhone,\n\n        creditLimit: customer.creditLimit,\n\n        currentOutstanding: customer.totalOutstanding,\n\n        exceededBy:\n          customer.totalOutstanding - customer.creditLimit,\n\n        invoiceCount: customer.invoices.length,\n\n        invoiceList: customer.invoices\n          .map(i => i.invoiceNumber)\n          .join(\", \")\n\n      }\n    });\n\n  }\n\n}\n\nreturn output;"
      },
