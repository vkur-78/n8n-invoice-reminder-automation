    {
      "parameters": {
        "jsCode": "const output = [];\n\nconst tomorrow = new Date();\ntomorrow.setHours(0,0,0,0);\ntomorrow.setDate(tomorrow.getDate() + 1);\n\nfor (const item of $input.all()) {\n\n  const row = item.json;\n\n  if (!row[\"PDC Date\"]) continue;\n\n  const pdc = new Date(row[\"PDC Date\"]);\n  pdc.setHours(0,0,0,0);\n\n  if (pdc.getTime() === tomorrow.getTime()) {\n    output.push({\n      json: row\n    });\n  }\n}\n\nreturn output;"
      },
